# ── Search Providers ──────────────────────────────────────────────────────────
# Brave Search API (https://api.search.brave.com)
BRAVE_API_KEY=your_brave_api_key_here

# SerpAPI / Google Search (https://serpapi.com)
SERPAPI_KEY=your_serpapi_key_here

# ── LLM Backend (LiteLLM format) ──────────────────────────────────────────────
# Local Ollama (default)
LITELLM_MODEL=ollama/llama3.1
LITELLM_API_BASE=http://localhost:11434

# OpenAI example:
# LITELLM_MODEL=gpt-4o-mini
# LITELLM_API_BASE=
# OPENAI_API_KEY=sk-...

# Anthropic example:
# LITELLM_MODEL=claude-haiku-20240307
# ANTHROPIC_API_KEY=sk-ant-...

# ── Evaluation Thresholds ─────────────────────────────────────────────────────
# Minimum composite confidence score (0.0–1.0) to accept a source
MIN_CONFIDENCE_SCORE=0.4

# Minimum authority level to accept (overridden per-session via constraints)
# Options: High | Medium | Low
MIN_AUTHORITY_LEVEL=Low

# ── Retry & Backoff ───────────────────────────────────────────────────────────
MAX_RETRY_COUNT=3
BACKOFF_BASE_DELAY=1.0
BACKOFF_MAX_DELAY=30.0

# ── Composite Score Weights ───────────────────────────────────────────────────
# confidence = AUTHORITY_WEIGHT * authority_score + RELEVANCE_WEIGHT * relevance_score
AUTHORITY_WEIGHT=0.4
RELEVANCE_WEIGHT=0.6

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./research.db
